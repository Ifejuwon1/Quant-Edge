{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and trading settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "accountCapital": { "type": "number", "description": "Total trading capital" },
        "currency": { "type": "string", "enum": ["USD", "GBP", "NGN"] },
        "theme": { "type": "string", "enum": ["dark", "light"] }
      },
      "required": ["id", "email"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A single trade journal entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "pair": { "type": "string", "description": "Trading pair (e.g., BTC/USDT)" },
        "timeframe": { "type": "string", "description": "Timeframe used for the trade" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "side": { "type": "string", "enum": ["long", "short"] },
        "leverage": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "result": { "type": "string", "enum": ["tp", "sl", "tsl", "breakeven", "none"] },
        "riskFollowed": { "type": "boolean" },
        "notes": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Base64 encoded screenshots (max 2)" },
        "timestamp": { "type": "string", "format": "date-time" },
        "tradeDate": { "type": "string", "format": "date", "description": "The date the trade was taken" }
      },
      "required": ["userId", "pair", "side", "entryPrice", "timestamp", "tradeDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "User's trade journal entries"
    }
  }
}
